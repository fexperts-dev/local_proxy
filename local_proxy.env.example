# local_proxy — combined tunnel server + client on this machine
#
# Prerequisite in /etc/hosts:
#   127.0.0.1  api.lmstudio.local
#
# Cursor (macOS): Keychain trust, http.noProxy — see INSTALLATION.md §5–§9
# Optional Shell (VPN/Proxy): NO_PROXY=127.0.0.1,localhost,api.lmstudio.local,.lmstudio.local
#
# Generate session.json on start (~/.local_proxy/). No registration secret needed.

LOCAL_DOMAIN=api.lmstudio.local
LOCAL_PORT=8443
LOCAL_PROXY_USE_TLS=true
LMSTUDIO_URL=http://localhost:1234
CLIENT_ID=my-laptop
LOCAL_PROXY_DATA_DIR=~/.local_proxy
LOCAL_PROXY_LOG_LEVEL=INFO
